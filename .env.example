PORT=3000

# ── Supabase (project ref: zmdokvjewvqaftnvulsr) ──────────────────────────────
#
# SUPABASE_URL + SUPABASE_ANON_KEY → cliente web y validación JWT en el API.
#   - El navegador usa supabase-js con la sesión del usuario (JWT).
#   - PostgREST ejecuta como rol `authenticated`; RLS filtra por tenant/rol.
#   - La anon key es pública por diseño; la seguridad viene del JWT + RLS.
#
# SUPABASE_SERVICE_ROLE_KEY → solo servidor (NestJS), nunca en el frontend.
#   - Admin API de Supabase Auth (crear usuarios, etc.).
#   - NO reemplaza validación de tenant en escrituras de negocio.
#
SUPABASE_URL=https://zmdokvjewvqaftnvulsr.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Postgres directo (Prisma / NestJS) ───────────────────────────────────────
#
# DATABASE_URL → conexión directa como rol `postgres` (bypass RLS).
#   - Usar en el API para lookups de auth y escrituras operativas sensibles.
#   - El servicio DEBE validar codigo_empresa, codigo_cuenta e id_bodega en código.
#   - Nunca exponer esta URL ni la service role key al cliente web.
#
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.zmdokvjewvqaftnvulsr.supabase.co:5432/postgres

# ── Seguridad (producción) ───────────────────────────────────────────────────
# NODE_ENV=production activa validación de secretos al arrancar (validateSecurityEnv).
# Rate limiting: ThrottlerModule (200 req/min default, 15 req/min auth).
MATEO_HANDOFF_SECRET=change-me-to-a-long-random-secret
# JWT del widget Mateo embebido (HS256). Distinto del handoff SSO one-time.
# Debe ser el MISMO secreto que usa n8n (POL-71) para validar Authorization Bearer.
MATEO_WIDGET_JWT_SECRET=change-me-to-another-long-random-secret
# Claims / header alineados al guard n8n (defaults = mock local-dev).
MATEO_WIDGET_JWT_ISSUER=bodega-frio-v2
MATEO_WIDGET_JWT_AUDIENCE=mateo-support-widget
MATEO_WIDGET_JWT_KID=local-dev-v1
# Orígenes CORS para mateo-exchange desde el navegador (chatbot-mateo directo).
# polaria-wms-web usa proxy /api y no requiere su origen aquí.
MATEO_ALLOWED_ORIGINS=https://chatbot-mateo.vercel.app,http://localhost:3000
